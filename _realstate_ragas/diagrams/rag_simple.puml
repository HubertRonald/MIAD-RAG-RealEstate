@startuml RealEstate_RAG_HighLevel
!theme plain
skinparam componentStyle rectangle

title "Sistema RAG Inmobiliario — Arquitectura de Alto Nivel"

actor "Usuario" as user

rectangle "API" {
  component "Endpoint de recomendación" as api
}

rectangle "Capa de Consulta" {
  component "Extracción de preferencias\n[Modos 2 & 3]" as pref #LightYellow
  component "Recuperación\nBúsqueda vectorial" as retrieval
  component "Generación\nLLM" as gen
}

database "Índice vectorial\n(FAISS)" as faiss

cloud "LLM" {
  component "Modelo generativo" as llm
}

user --> api : "Modo 1: filtros estructurados\nModo 2: texto libre\nModo 3: combinado"

api --> pref : "Modos 2 & 3"
api --> retrieval : "Modo 1"
pref --> retrieval : "filtros enriquecidos"

retrieval --> faiss : "búsqueda semántica"
retrieval --> gen : "contexto recuperado"
gen --> llm : "prompt + contexto"
gen --> user : "recomendaciones"

note right of user
  <b>Modo 1 — Filtros estructurados</b>
  Barrio: Pocitos
  Tipo: Apartamento
  Precio máx: 200.000 USD
  Dormitorios: 2
  Pregunta: (vacía)
end note

note right of pref
  <b>Modo 2 — Texto libre</b>
  "Busco algo tranquilo cerca del mar,
  con buena luz, que no sea muy caro
  y tenga espacio para trabajar desde casa"
  → el sistema infiere: zona costera,
    precio moderado, ambientes amplios
end note

note right of pref
  <b>Modo 3 — Combinado</b>
  Tipo: Apartamento (filtro duro)
  Barrio: Carrasco (filtro duro)
  + "que tenga terraza y sea moderno,
  pensando en una familia con niños"
  → extracción enriquece con:
    amenities, antigüedad, seguridad
end note
@enduml